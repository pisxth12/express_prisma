generator client{
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User{
     id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}
model Category {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String    @unique
  isActive  Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("categories")
}

model Product {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  slug           String    @unique
  description    String?
  original_price Decimal
  discount_price Decimal?
  isActive       Boolean   @default(true)
  image_url      String?
  category_id    String?   @db.Uuid
  category       Category? @relation(fields: [category_id], references: [id])
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("products")
}

model Contact {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tiktok     String?
  facebook   String?
  telegram   String?
  google_map String?
  telephone  String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("contacts")
}

model BlacklistToken {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now()) @map("created_at")
  
   @@index([expiresAt])
  @@map("blacklisted_tokens")
}